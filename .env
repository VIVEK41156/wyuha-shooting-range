# Database Connection String
# Replace postgres, password, and 5432 with your actual credentials and port
# The database wyuha_db must exist
DATABASE_URL=postgresql://postgres:password@localhost:5432/wyuha_db

# Backend Port
PORT=5000

# Email Configuration (Nodemailer)
# If using Gmail, you need an "App Password" (not your normal login password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
RECEIVER_EMAIL=where_to_send_emails@example.com
